<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calorimate</title>  
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin: 50px;
            background-color: #f4f4f4;
        }
        .container {
            max-width: 500px;
            margin: auto;
            padding: 20px;
            background: white;
            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }
        input, button {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 5px;
        }
        button {
            background-color: #28a745;
            color: white;
            cursor: pointer;
            border: none;
        }
        button:hover {
            background-color: #218838;
        }
        
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin: 50px;
            background-color: #f4f4f4;
        }
        .container {
            max-width: 500px;
            margin: auto;
            padding: 20px;
            background: white;
            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }
        input, button {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Calorie Predictor</h2>
        <p>Enter a food item to predict its calorie content:</p>
        <input type="text" id="foodInput" placeholder="Enter food name...">
        <button onclick="predictCalories()">Predict</button>
        <h3 id="result"></h3>
    </div>

    <script>
        function predictCalories() {
            let food = document.getElementById("foodInput").value;
            let result = document.getElementById("result");
            
            // Dummy calorie values (to be replaced with backend API call)
            let calories = {
                "apple": 95,
                "banana": 105,
                "burger": 354,
                "pizza": 285,
                "rice": 206
            };
            
            if (food.toLowerCase() in calories) {
                result.innerText = `Estimated Calories: ${calories[food.toLowerCase()]} kcal`;
            } else {
                result.innerText = "Calorie data not available.";
            }
        }
    </script>
</body>
</html>
